# Copy this file to .env for local runs (do not commit real values).
# Databricks jobs can instead use dbutils.secrets.get with scope kv_databricks_scope.

PROJECT322_RIOT_API_KEY=replace_me
PROJECT322_OPENWEATHER_API_KEY=replace_me
PROJECT322_GOOGLE_TRENDS_PROXY=

# Optional runtime configs
SECRETS_SCOPE=kv_databricks_scope
TRACKED_PUUIDS=puuid_1,puuid_2
RIOT_REGIONAL_ROUTING=americas
RIOT_PLATFORM_ROUTING=na1
GOOGLE_TRENDS_TIMEFRAME=today 3-m
GOOGLE_TRENDS_GEOS=US,DE,KR
GOOGLE_TRENDS_CHAMPION_TERMS=ahri,yasuo,jinx,lee sin,lux
GOOGLE_TRENDS_PATCH_TERMS=league of legends patch,lol patch notes,league patch
